# ── Output directory ───────────────────────────────────────────────
# Where scrapers write their JSON output files.
# Defaults to current directory if not set.
OUTPUT_DIR=./data

# ── Canada (CanLII) ────────────────────────────────────────────────
# Free API key — register at https://developer.canlii.org/
CANLII_API_KEY=YOUR_CANLII_API_KEY

# ── Legal Data Hunter (optional) ───────────────────────────────────
# Used for cross-jurisdictional legal search (legaldatahunter.com)
# Not required for the scrapers themselves.
LEGAL_DATA_HUNTER_API_KEY=YOUR_LEGAL_DATA_HUNTER_KEY
